# ── Server-side only (Vercel env vars — never in browser) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: restricts /api/system-status to admin only
SYSTEM_STATUS_KEY=your-secret-admin-key

# ── Mobile chat (Vite public — safe to expose, no secrets) ───────────────────
# URL of the Next.js API (apps/web deployment)
# Set in Vercel: apps/mobile-chat project → Environment Variables
VITE_API_URL=https://your-web-app.vercel.app
